  "metadata": {
    "author": "PaperNormAI Team",
    "description": "清华大学硕士学位论文格式规范",
    "tags": ["清华大学", "硕士", "计算机科学"]
  },
  "rules": [
    {
      "id": "font_name_body",
      "name": "正文字体",
      "level": "L1",
      "description": "正文应使用宋体",
      "severity": "error",
      "auto_fixable": true,
      "params": {
        "expected_value": "宋体",
        "allowed_fonts": ["宋体", "SimSun"]
      }
    },
    {
      "id": "font_name_heading",
      "name": "标题字体",
      "level": "L1",
      "description": "标题应使用黑体",
      "severity": "error",
      "auto_fixable": true,
      "params": {
        "expected_value": "黑体",
        "allowed_fonts": ["黑体", "SimHei"]
      }
    },
    {
      "id": "font_size_body",
      "name": "正文字号",
      "level": "L1",
      "description": "正文应使用小四号字（12pt）",
      "severity": "error",
      "auto_fixable": true,
      "params": {
        "expected_value": 12,
        "unit": "pt"
      }
    },
    {
      "id": "line_spacing",
      "name": "行距",
      "level": "L1",
      "description": "正文行距应为1.5倍",
      "severity": "error",
      "auto_fixable": true,
      "params": {
        "expected_value": 1.5,
        "tolerance": 0.1
      }
    },
    {
      "id": "paragraph_spacing",
      "name": "段前段后间距",
      "level": "L1",
      "description": "段落段前0.5行，段后0行",
      "severity": "warning",
      "auto_fixable": true,
      "params": {
        "space_before": 0.5,
        "space_after": 0
      }
    },
    {
      "id": "page_margin",
      "name": "页边距",
      "level": "L1",
      "description": "页边距：上下2.54cm，左右3cm",
      "severity": "error",
      "auto_fixable": false,
      "params": {
        "top": 2.54,
        "bottom": 2.54,
        "left": 3.0,
        "right": 3.0,
        "unit": "cm"
      }
    },
    {
      "id": "heading_level",
      "name": "标题层级",
      "level": "L2",
      "description": "标题层级应连续，不能跳级",
      "severity": "error",
      "auto_fixable": false,
      "params": {
        "max_level": 4
      }
    },
    {
      "id": "citation_format",
      "name": "引用格式",
      "level": "L3",
      "description": "引用应符合学术规范",
      "severity": "warning",
      "auto_fixable": false,
      "params": {
        "style": "academic"
      }
    }
  ]
